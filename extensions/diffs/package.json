{
  "name": "@crawclaw/diffs",
  "version": "2026.4.1-beta.1",
  "private": true,
  "description": "CrawClaw diff viewer plugin",
  "type": "module",
  "scripts": {
    "build:viewer": "bun build src/viewer-client.ts --target browser --format esm --minify --outfile assets/viewer-runtime.js"
  },
  "dependencies": {
    "@pierre/diffs": "1.1.7",
    "@pierre/theme": "0.0.26",
    "@sinclair/typebox": "0.34.49",
    "playwright-core": "1.58.2"
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "releaseChecks": {
      "rootDependencyMirrorAllowlist": [
        "@pierre/diffs",
        "@pierre/theme",
        "playwright-core"
      ]
    }
  }
}
