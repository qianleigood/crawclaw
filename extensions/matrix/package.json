{
  "name": "@crawclaw/matrix",
  "version": "2026.4.20",
  "description": "CrawClaw Matrix channel plugin",
  "type": "module",
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-nodejs": "^0.4.0",
    "@matrix-org/matrix-sdk-crypto-wasm": "18.1.0",
    "@sinclair/typebox": "0.34.49",
    "fake-indexeddb": "^6.2.5",
    "jiti": "^2.6.1",
    "markdown-it": "14.1.1",
    "matrix-js-sdk": "41.3.0",
    "music-metadata": "^11.12.3"
  },
  "devDependencies": {
    "crawclaw": "workspace:*"
  },
  "peerDependencies": {
    "crawclaw": ">=2026.4.1-beta.1"
  },
  "peerDependenciesMeta": {
    "crawclaw": {
      "optional": true
    }
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "matrix",
      "label": "Matrix",
      "selectionLabel": "Matrix (plugin)",
      "docsPath": "/channels/matrix",
      "docsLabel": "matrix",
      "blurb": "open protocol; install the plugin to enable.",
      "order": 70,
      "quickstartAllowFrom": true,
      "profile": "optional",
      "persistedAuthState": {
        "specifier": "./auth-presence",
        "exportName": "hasAnyMatrixAuth"
      }
    },
    "cli": {
      "descriptors": [
        {
          "name": "matrix",
          "description": "Manage Matrix accounts, verification, devices, and profile state",
          "descriptionZhCN": "管理 Matrix 账号、验证、设备和资料状态",
          "hasSubcommands": true
        }
      ]
    },
    "install": {
      "npmSpec": "@crawclaw/matrix",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    },
    "releaseChecks": {
      "rootDependencyMirrorAllowlist": [
        "@matrix-org/matrix-sdk-crypto-wasm",
        "@matrix-org/matrix-sdk-crypto-nodejs",
        "matrix-js-sdk"
      ]
    }
  }
}
