{
  "name": "@crawclaw/twitch",
  "version": "2026.4.1-beta.1",
  "description": "CrawClaw Twitch channel plugin",
  "type": "module",
  "dependencies": {
    "@twurple/api": "^8.1.3",
    "@twurple/auth": "^8.1.3",
    "@twurple/chat": "^8.1.3"
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.4.1"
    },
    "channel": {
      "id": "twitch",
      "label": "Twitch",
      "selectionLabel": "Twitch (Chat)",
      "docsPath": "/channels/twitch",
      "blurb": "Twitch chat integration",
      "aliases": [
        "twitch-chat"
      ],
      "profile": "optional"
    }
  }
}
