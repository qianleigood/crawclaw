{
  "name": "@crawclaw/synology-chat",
  "version": "2026.4.1-beta.1",
  "description": "Synology Chat channel plugin for CrawClaw",
  "type": "module",
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to CrawClaw with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@crawclaw/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    }
  }
}
