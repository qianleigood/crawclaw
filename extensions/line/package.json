{
  "name": "@crawclaw/line",
  "version": "2026.4.20",
  "private": true,
  "description": "CrawClaw LINE channel plugin",
  "type": "module",
  "dependencies": {
    "@line/bot-sdk": "^11.0.0"
  },
  "devDependencies": {
    "crawclaw": "workspace:*"
  },
  "peerDependencies": {
    "crawclaw": ">=2026.4.1-beta.1"
  },
  "peerDependenciesMeta": {
    "crawclaw": {
      "optional": true
    }
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "line",
      "label": "LINE",
      "selectionLabel": "LINE (Messaging API)",
      "detailLabel": "LINE Bot",
      "docsPath": "/channels/line",
      "docsLabel": "line",
      "blurb": "LINE Messaging API webhook bot.",
      "systemImage": "message",
      "order": 75,
      "quickstartAllowFrom": true,
      "profile": "optional"
    },
    "install": {
      "npmSpec": "@crawclaw/line",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    }
  }
}
