{
  "name": "@crawclaw/slack",
  "version": "2026.4.1-beta.1",
  "private": true,
  "description": "CrawClaw Slack channel plugin",
  "type": "module",
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.15.0"
