{
  "name": "@crawclaw/nostr",
  "version": "2026.4.1-beta.1",
  "description": "CrawClaw Nostr channel plugin for NIP-04 encrypted DMs",
  "type": "module",
  "dependencies": {
    "nostr-tools": "^2.23.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "crawclaw": "workspace:*"
  },
  "peerDependencies": {
    "crawclaw": ">=2026.4.1-beta.1"
  },
  "peerDependenciesMeta": {
    "crawclaw": {
      "optional": true
    }
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nostr",
      "label": "Nostr",
      "selectionLabel": "Nostr (NIP-04 DMs)",
      "docsPath": "/channels/nostr",
      "docsLabel": "nostr",
      "blurb": "Decentralized protocol; encrypted DMs via NIP-04.",
      "order": 55,
      "quickstartAllowFrom": true,
      "profile": "optional"
    },
    "install": {
      "npmSpec": "@crawclaw/nostr",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
