{
  "name": "@crawclaw/msteams",
  "version": "2026.4.1-beta.1",
  "description": "CrawClaw Microsoft Teams channel plugin",
  "type": "module",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/teams.api": "2.0.8",
    "@microsoft/teams.apps": "2.0.8",
    "@sinclair/typebox": "0.34.49",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1"
  },
  "devDependencies": {
    "crawclaw": "workspace:*"
  },
  "peerDependencies": {
    "crawclaw": ">=2026.4.1-beta.1"
  },
  "peerDependenciesMeta": {
    "crawclaw": {
      "optional": true
    }
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "msteams",
      "label": "Microsoft Teams",
      "selectionLabel": "Microsoft Teams (Teams SDK)",
      "docsPath": "/channels/msteams",
      "docsLabel": "msteams",
      "blurb": "Teams SDK; enterprise support.",
      "aliases": [
        "teams"
      ],
      "order": 60,
      "profile": "optional"
    },
    "install": {
      "npmSpec": "@crawclaw/msteams",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
