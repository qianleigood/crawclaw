{
  "name": "@crawclaw/whatsapp",
  "version": "2026.4.20",
  "description": "CrawClaw WhatsApp channel plugin",
  "type": "module",
  "dependencies": {
    "@sinclair/typebox": "0.34.49",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "jimp": "^1.6.1",
    "qrcode-terminal": "^0.12.0",
    "undici": "8.1.0"
  },
  "devDependencies": {
    "crawclaw": "workspace:*"
  },
  "peerDependencies": {
    "crawclaw": ">=2026.4.1-beta.1"
  },
  "peerDependenciesMeta": {
    "crawclaw": {
      "optional": true
    }
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "whatsapp",
      "label": "WhatsApp",
      "selectionLabel": "WhatsApp (QR link)",
      "detailLabel": "WhatsApp Web",
      "docsPath": "/channels/whatsapp",
      "docsLabel": "whatsapp",
      "blurb": "works with your own number; recommend a separate phone + eSIM.",
      "systemImage": "message",
      "profile": "optional",
      "persistedAuthState": {
        "specifier": "./auth-presence",
        "exportName": "hasAnyWhatsAppAuth"
      }
    },
    "install": {
      "npmSpec": "@crawclaw/whatsapp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
