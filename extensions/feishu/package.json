{
  "name": "@crawclaw/feishu",
  "version": "2026.4.20",
  "description": "CrawClaw Feishu/Lark channel plugin (community maintained by @m1heng)",
  "type": "module",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@sinclair/typebox": "0.34.49",
    "https-proxy-agent": "^8.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "crawclaw": "workspace:*"
  },
  "peerDependencies": {
    "crawclaw": ">=2026.4.1-beta.1"
  },
  "peerDependenciesMeta": {
    "crawclaw": {
      "optional": true
    }
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true,
      "profile": "primary-cn"
    },
    "install": {
      "npmSpec": "@crawclaw/feishu",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "startup": {
      "deferConfiguredChannelFullLoadUntilAfterListen": true
    },
    "release": {
      "publishToNpm": true
    }
  }
}
