{
  "name": "@crawclaw/whatsapp",
  "version": "2026.4.1-beta.1",
  "description": "CrawClaw WhatsApp channel plugin",
  "type": "module",
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "jimp": "^1.6.0"
  },
  "devDependencies": {
    "crawclaw": "workspace:*"
  },
  "peerDependencies": {
    "crawclaw": ">=2026.4.1-beta.1"
  },
  "peerDependenciesMeta": {
    "crawclaw": {
      "optional": true
    }
  },
  "crawclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "whatsapp",
      "label": "WhatsApp",
      "selectionLabel": "WhatsApp (QR link)",
      "detailLabel": "WhatsApp Web",
      "docsPath": "/channels/whatsapp",
      "docsLabel": "whatsapp",
      "blurb": "works with your own number; recommend a separate phone + eSIM.",
      "systemImage": "message",
      "profile": "optional"
    },
    "install": {
      "npmSpec": "@crawclaw/whatsapp",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
